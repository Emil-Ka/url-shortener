# --- URL Service (скопируй в url/.env) ---

# MongoDB: строка подключения и имя базы
MONGO_URI=mongodb://localhost:27017
MONGO_DB=url_shortener

# Redis (тот же общий инстанс, что и у User Service)
REDIS_HOST=localhost
REDIS_PORT=6379

# Адрес gRPC-сервера User Service — куда стучаться за GetLimit
USER_SERVICE_ADDR=localhost:50051

# Порт, на котором слушает URL Service (gRPC)
URL_SERVICE_PORT=50052

# База для сборки short_url: SHORT_URL_BASE + "/" + short_code
SHORT_URL_BASE=https://short.url

# Kafka (добавляется на третьей неделе — producer click-событий)
KAFKA_BROKERS=localhost:9092
