# --- Analytics Service (скопируй в analytics/.env) ---

# Kafka — откуда читаем click_events
KAFKA_BROKERS=localhost:9092

# ClickHouse (native-протокол, порт 9000) и база
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DB=default

# Адрес gRPC URL Service — для проверки владельца ссылки (URL.GetURL)
URL_SERVICE_ADDR=localhost:50052

# Порт gRPC Analytics Service
ANALYTICS_SERVICE_PORT=50053
