# --- API Gateway (скопируй в gateway/.env) ---

# Порт HTTP-сервера Gateway (единственная публичная точка входа)
GATEWAY_PORT=8080

# Адреса gRPC-сервисов, куда Gateway проксирует
USER_SERVICE_ADDR=localhost:50051
URL_SERVICE_ADDR=localhost:50052
# ANALYTICS_SERVICE_ADDR=localhost:50053   # добавится на четвёртой неделе

# JWT-секрет Gateway НЕ нужен: токен валидирует User Service
# (Gateway зовёт User.ValidateSession), сам Gateway секрет не знает.
