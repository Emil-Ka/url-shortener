# --- User Service (скопируй в user/.env) ---

# PostgreSQL. Логин/пароль/база должны совпадать с дефолтами в docker-compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/url_shortener?sslmode=disable

# Redis (один общий инстанс на все сервисы)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT: секрет знает только User Service — он подписывает и валидирует токены.
JWT_SECRET=your-secret-key-change-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Порт, на котором слушает User Service (gRPC)
USER_SERVICE_PORT=50051
